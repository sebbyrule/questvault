{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Consumed directly by the Next.js/service bundlers (exports point at .ts
    // source), never emitted by tsc — so use Bundler resolution while keeping
    // the strict checking from the base config.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    // The @modelcontextprotocol/sdk transport types are not authored against
    // exactOptionalPropertyTypes (e.g. stateless `sessionIdGenerator: undefined`,
    // `onclose`), so relax just this one flag for the SDK-integrating package.
    "exactOptionalPropertyTypes": false
  },
  "include": ["src"]
}
