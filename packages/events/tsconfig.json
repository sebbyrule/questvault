{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Consumed by the worker (tsx/Node) and by web/MCP publishers. Bundler
    // resolution lets the extensionless relative imports resolve to .ts source.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src"]
}
