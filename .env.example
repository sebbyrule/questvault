# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://questvault:password@localhost:5432/questvault_dev
DATABASE_URL_TEST=postgresql://questvault:password@localhost:5432/questvault_test

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET=dev_secret_change_in_production
NEXTAUTH_URL=http://localhost:3000

# ─── Auth provider: "credentials" uses local username+password (no OAuth needed)
# Set to "credentials" for local dev, "github" or "google" for production.
AUTH_PROVIDER=credentials

# OAuth providers — only needed when AUTH_PROVIDER=github or AUTH_PROVIDER=google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── LM Studio (local LLM — OpenAI-compatible) ───────────────────────────────
# Start LM Studio, load a model, and enable the local server (default port 1234).
# The model name must match exactly what LM Studio shows in the server tab.
LLM_PROVIDER=lmstudio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-12b
# Leave blank — LM Studio doesn't require an API key locally
LM_STUDIO_API_KEY=lm-studio

# Keep these for when you eventually switch to Anthropic in production:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Embeddings ──────────────────────────────────────────────────────────────
# LM Studio can also serve an embedding model.
# If you don't have one loaded, set USE_EMBEDDINGS=false to disable vector search.
USE_EMBEDDINGS=false
EMBEDDING_BASE_URL=http://localhost:1234/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=lm-studio

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_AGENT_SECRET=dev_mcp_secret
MCP_AGENT_REPORTER_ID=00000000-0000-0000-0000-000000000000

# ─── Storage ─────────────────────────────────────────────────────────────────
# "local" writes to ./uploads/ on disk (no AWS needed).
# Switch to "s3" when deploying.
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# Only needed when STORAGE_PROVIDER=s3:
# S3_BUCKET=questvault-dev
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
MCP_PORT=3003
LOG_LEVEL=debug
